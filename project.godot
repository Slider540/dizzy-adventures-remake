; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Dizzy Adventures Remake"
config/description="Unofficial fan remake of classic Dizzy adventure games."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/icons/app_icon_512.png"

[autoload]

DisplayManager="*res://core/autoload/display_manager.gd"
GameManager="*res://core/autoload/game_manager.gd"
ScreenManager="*res://core/screens/screen_manager.gd"
Inventory="*res://core/inventory/inventory.gd"
Lives="*res://core/autoload/lives.gd"

[display]

window/size/viewport_width=512
window/size/viewport_height=384
window/stretch/mode="viewport"
window/stretch/scale="integer"
window/stretch/scale_3d="integer"

